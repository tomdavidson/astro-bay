{
  "name": "@astro-bay/eslint-config",
  "version": "0.1.0",
  "description": "ESLint flat config for TypeScript with clean architecture boundaries, FP enforcement, oxlint, and oxlint dedup.",
  "type": "module",
  "exports": {
    ".": "./src/index.mjs",
    "./rules": "./src/rules.mjs",
    "./layers": "./src/layers.mjs",
    "./oxlintrc.json": "./src/oxlintrc.json"
  },
  "main": "./src/index.mjs",
  "bin": {
    "install-oxlintrc": "./src/install-oxlintrc.mjs"
  },
  "files": ["src"],
  "keywords": ["eslint", "eslintconfig", "oxlint", "typescript", "functional", "clean-architecture", "boundaries"],
  "license": "MIT",
  "dependencies": {
    "eslint-plugin-boundaries": "^6.0.0",
    "eslint-plugin-functional": "^9.0.0",
    "eslint-plugin-oxlint": "^1.51.0",
    "eslint-plugin-prefer-arrow-functions": "^3.6.0",
    "jsonc-parser": "^3.3.1",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "typescript-eslint": "^8.58.0"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  }
}
