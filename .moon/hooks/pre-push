#!/usr/bin/env bash
set -eo pipefail

for (( i=0; i <= $#; i++ )); do
  declare -x "ARG$i"="${!i}"
done

# Automatically generated by moon. DO NOT MODIFY!
# https://moonrepo.dev/docs/guides/vcs-hooks

git diff --quiet && git diff --cached --quiet || (echo 'Dirty working tree. Commit all changes before pushing.' && exit 1)
moon run :lint --affected
moon run :fmt-check --affected
moon run :test --affected

