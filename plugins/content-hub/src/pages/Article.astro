---
import type { GetStaticPaths } from 'astro'
import { getCollection } from 'astro:content'
import type { ResolvedConfig } from '../config.ts'
import { getHubData } from '../infra/hub-data.ts'
import { slugifyTopic } from '../taxonomy.ts'
// @ts-ignore virtual module resolved by Vite plugin
import config from 'astro-content-hub:config'

import Breadcrumb from '../components/Breadcrumb.astro'
import DateDisplay from '../components/DateDisplay.astro'
import DraftBanner from '../components/DraftBanner.astro'
import PageShell from '../components/PageShell.astro'
import SourceBadge from '../components/SourceBadge.astro'
import TopicBadge from '../components/TopicBadge.astro'

export const prerender = true

export const getStaticPaths = (async () => {
  const data = await getHubData(config as ResolvedConfig, getCollection, {
    logger: {
      warn: (msg: string) => console.warn(msg),
      info: (msg: string) => console.warn(`INFO: ${msg}`),
    },
    command: config.astroCommand,
  })

  const collectionEntries =
    (await Promise.all(config.collections.map((c: string) => getCollection(c)))).flat()

  const entryMap = new Map(collectionEntries.map((e: unknown) => [(e as { id: string }).id, e]))

  return [...data.uidMap.entries()].map(([uid, entry]) => {
    const pagefindTopics = [
      ...new Set(entry.resolvedTopics.map(slug => data.topicMap.get(slug) ?? slug)),
    ]

    return {
      params: { uid },
      props: { entry, rawEntry: entryMap.get(entry.sourceId ?? entry.uid), pagefindTopics },
    }
  })
}) satisfies GetStaticPaths

const { entry, rawEntry, pagefindTopics } = Astro.props
const renderable = rawEntry as undefined | { render?: () => Promise<{ Content: unknown }> }
const rendered = renderable?.render ? await renderable.render() : undefined
const Content = rendered?.Content

const articleBase = config.permalinks.articleBase
const taxonomyRoute = config.taxonomy.route
const isDraft = entry.meta?.isDraftPreview === true
const canonicalUrl = config.siteUrl ?
  `${config.siteUrl.replace(/\/$/, '')}/${articleBase}/${entry.uid}` :
  undefined

const breadcrumbItems = [{ label: config.locale.indexTitle, href: `/${articleBase}` }, {
  label: entry.title,
}]
---

<PageShell
  title={entry.title}
  description={entry.excerpt}
  lang={config.locale.lang}
  canonicalUrl={canonicalUrl}
  jsonldHref="./index.jsonld"
>
  <main class="ch-article">
    <article data-pagefind-body>
      {isDraft && <DraftBanner />}

      <Breadcrumb items={breadcrumbItems} />

      <header>
        <h1 data-pagefind-weight="10">{entry.title}</h1>
        <div class="ch-article-meta">
          {entry.date && <DateDisplay date={entry.date} locale={config.locale.dateLocale} />}
          {
            entry.source !== 'vault' && (
              <SourceBadge
                source={entry.source}
                link={entry.source === 'feed' ? entry.link : undefined}
              />
            )
          }
        </div>
        {
          entry.topics.length > 0 && (
            <div class="ch-article-topics">
              {
                entry.topics.map((topic: string) => (
                  <TopicBadge topic={topic} slug={slugifyTopic(topic)} baseUrl={taxonomyRoute} />
                ))
              }
            </div>
          )
        }
      </header>

      <div class="ch-article-body">
        {Content ? <Content /> : entry.excerpt !== undefined ? <p>{entry.excerpt}</p> : undefined}
      </div>

      {
        entry.source === 'feed' && entry.link && (
          <p class="ch-read-original">
            <a href={entry.link} target="_blank" rel="noopener noreferrer">
              Read the original &rarr;
            </a>
          </p>
        )
      }

      {
        pagefindTopics.map((label: string) => (
          <meta data-pagefind-filter="topic[content]" content={label} />
        ))
      }
      <meta data-pagefind-filter="source[content]" content={entry.source} />
      {
        entry.date && (
          <meta
            data-pagefind-meta="date[content]"
            content={entry.date.toISOString().slice(0, 10)}
          />
        )
      }
      <meta data-pagefind-meta="uid[content]" content={entry.uid} />
      {entry.excerpt && <meta data-pagefind-meta="excerpt[content]" content={entry.excerpt} />}
    </article>
  </main>
</PageShell>

<style>
.ch-article {
  max-width: 48rem;
  margin: 0 auto;
  padding: 2rem 1rem;
}
h1 {
  font-size: 1.75rem;
  font-weight: 700;
  margin: 0.5rem 0;
  line-height: 1.2;
}
.ch-article-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
  margin: 0.5rem 0;
}
.ch-article-topics {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin: 0.75rem 0 1.5rem;
}
.ch-article-body {
  line-height: 1.7;
  max-width: 65ch;
}
.ch-read-original {
  margin-top: 1.5rem;
  font-size: 0.9375em;
}
.ch-read-original a {
  color: var(--ch-accent, #0369a1);
  text-decoration: none;
}
.ch-read-original a:hover {
  text-decoration: underline;
}
</style>
