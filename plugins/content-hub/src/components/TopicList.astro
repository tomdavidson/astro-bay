---
import TopicBadge from './TopicBadge.astro'

type TopicWithCount = { readonly slug: string; readonly label: string; readonly count: number }

type Props = { topics: ReadonlyArray<TopicWithCount>; baseUrl: string; limit?: number }

const { topics, baseUrl, limit } = Astro.props
const visible = limit === undefined ? topics : topics.slice(0, limit)
---

<div class="ch-topic-list" role="list">
  {
    visible.map(t => (
      <div role="listitem">
        <TopicBadge topic={t.label} slug={t.slug} count={t.count} baseUrl={baseUrl} />
      </div>
    ))
  }
</div>

<style>
.ch-topic-list {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}
</style>
