---
interface Props {
  source: string
  link?: string
}

const { source, link } = Astro.props
---

{link ? (
  <a class="ch-source-badge" href={link} target="_blank" rel="noopener noreferrer">
    {source}<span class="ch-source-external" aria-hidden="true">\u2197</span>
  </a>
) : (
  <span class="ch-source-badge">{source}</span>
)}

<style>
  .ch-source-badge {
    display: inline-block;
    padding: 0.125em 0.5em;
    font-size: 0.75em;
    font-family: var(--ch-font-body, inherit);
    color: var(--ch-text-muted, #6b7280);
    background: var(--ch-surface, #f3f4f6);
    border: 1px solid var(--ch-border, #e5e7eb);
    border-radius: var(--ch-radius, 0.375rem);
    text-decoration: none;
    line-height: 1.5;
  }
  a.ch-source-badge:hover {
    color: var(--ch-text, #111827);
    border-color: var(--ch-text-muted, #6b7280);
  }
  .ch-source-external {
    margin-left: 0.2em;
    font-size: 0.85em;
  }
</style>
