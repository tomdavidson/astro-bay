---
import type { NormalizedEntry } from '../types.ts'
import { slugifyTopic } from '../taxonomy.ts'
import DateDisplay from './DateDisplay.astro'
import SourceBadge from './SourceBadge.astro'
import TopicBadge from './TopicBadge.astro'

type Props = {

  entry: NormalizedEntry
  baseUrl: string
  taxonomyBase?: string
  dateLocale?: string
}

const { entry, baseUrl, taxonomyBase = 'topics', dateLocale = 'en-US' } = Astro.props
const href = `/${baseUrl}/${entry.uid}`
const isDraft = entry.meta?.isDraftPreview === true
---

<article class:list={['ch-article-card', { 'ch-article-card--draft': isDraft }]}>
  <a class="ch-card-link" href={href}>
    <h3 class="ch-card-title">{entry.title}</h3>
  </a>

  <div class="ch-card-meta">
    {entry.date && <DateDisplay date={entry.date} locale={dateLocale} />}
    {isDraft && <span class="ch-card-draft-badge">Draft</span>}
    {entry.source !== 'vault' && (
      <SourceBadge source={entry.source} link={entry.source === 'feed' ? entry.link : undefined} />
    )}
  </div>

  {entry.excerpt && <p class="ch-card-excerpt">{entry.excerpt}</p>}

  {entry.topics.length > 0 && (
    <div class="ch-card-topics">
      {entry.topics.map((topic: string) => (
        <TopicBadge topic={topic} slug={slugifyTopic(topic)} baseUrl={taxonomyBase} />
      ))}
    </div>
  )}
</article>

<style>
  .ch-article-card {
    padding: 1rem 0;
    border-bottom: 1px solid var(--ch-border, #e5e7eb);
    font-family: var(--ch-font-body, inherit);
  }
  .ch-article-card:last-child {
    border-bottom: none;
  }
  .ch-article-card--draft {
    opacity: 0.7;
  }
  .ch-card-link {
    text-decoration: none;
    color: inherit;
  }
  .ch-card-link:hover .ch-card-title {
    color: var(--ch-accent, #0369a1);
  }
  .ch-card-title {
    font-size: 1.125em;
    font-weight: 600;
    color: var(--ch-text, #111827);
    margin: 0 0 0.35rem;
    line-height: 1.3;
  }
  .ch-card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }
  .ch-card-draft-badge {
    display: inline-block;
    padding: 0.1em 0.4em;
    font-size: 0.75em;
    font-weight: 600;
    color: #92400e;
    background: #fef3c7;
    border-radius: var(--ch-radius, 0.25rem);
  }
  .ch-card-excerpt {
    font-size: 0.9375em;
    color: var(--ch-text-muted, #6b7280);
    margin: 0.25rem 0 0.5rem;
    line-height: 1.5;
    max-width: 65ch;
  }
  .ch-card-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.25rem;
  }
</style>
