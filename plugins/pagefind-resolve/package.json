{
  "name": "@astro-bay/pagefind-resolve",
  "version": "0.4.0",
  "description": "Client-side 404 resolution via Pagefind with structured logging.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./components": {
      "types": "./src/components/index.d.ts",
      "default": "./src/components/Resolve404.astro"
