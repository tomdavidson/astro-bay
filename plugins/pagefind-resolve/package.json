    "./config": "./src/config.ts",
    "./client": "./src/client/shell.ts"
  },
  "peerDependencies": { "astro": ">=5.0.0", "astro-pagefind": ">=1.0.0" },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "astro": "^5.0.0",
    "fast-check": "^3.22.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "TDD=1 vitest --watch",
