---
/**
 * Drop-in 404 resolution component.
 *
 * Usage in your src/pages/404.astro:
 *
 *   ---
 *   import Layout from '../layouts/Base.astro'
 *   import Resolve404 from '@astro-bay/pagefind-resolve/components'
 *   ---
 *   <Layout title="Page not found">
 *     <h1>Page not found</h1>
 *     <Resolve404 stripBases={['articles']} />
 *   </Layout>
 *
 * The component renders unstyled semantic HTML. Style with .pfr-* class hooks.
 * Listen for the typed resolution event:
 *   document.addEventListener('pfr:resolve', (e: PfrResolveEvent) => { ... })
 */

import { mergeConfig } from '@astro-bay/pagefind-resolve/config'
import type { Smart404Options } from '@astro-bay/pagefind-resolve/config'

export interface Props extends Smart404Options {
  class?: string
}

const { class: className, ...options } = Astro.props
const config = mergeConfig(options)

// A unique per-render ID prevents document.querySelector('[data-pfr-config]')
// from matching the wrong element when multiple components are on the same page.
// crypto.randomUUID() is available in Node 19+ / Astro build time.
const instanceId = crypto.randomUUID()
---

<div
  id={`pfr-${instanceId}`}
  data-pfr-config={JSON.stringify(config)}
  class:list={['pfr-resolve', className]}
>
  <p data-pfr-status class="pfr-status">Checking for a match&hellip;</p>
  <ul data-pfr-suggestions class="pfr-suggestions" hidden></ul>
  <p data-pfr-search-link class="pfr-search-link" hidden>
    Try <a href={config.searchRoute}>searching</a> instead.
  </p>
</div>

<script>
import { initResolve404 } from '@astro-bay/pagefind-resolve/client'

document.querySelectorAll<HTMLElement>('[data-pfr-config]').forEach(root => {
  initResolve404(root)
})
</script>
