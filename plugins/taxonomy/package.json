{
  "name": "@astro-bay/taxonomy",
  "version": "0.1.0",
  "description": "Derives, curates, and exposes a taxonomy graph as a shared virtual module for Astro integrations.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "astro-taxonomy": "./src/bin/derive.js"
  },
  "exports": {
    ".": "./src/integration.ts",
    "./providers": "./src/providers/index.ts",
    "./types": "./src/types.ts"
  },
  "peerDependencies": {
    "astro": ">=5.0.0",
    "zod": ">=3.23.0"
  },
  "dependencies": {
    "neverthrow": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "astro": "^5.0.0",
    "fast-check": "^3.22.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "TDD=1 vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint:ox": "oxlint --fix --config ../../oxlint.config.ts",
    "lint:es": "eslint --fix"
  }
}
